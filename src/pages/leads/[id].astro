---
import Layout from '../../layouts/Layout.astro'
import ScoreBadge from '../../components/ScoreBadge.astro'
import StatusBadge from '../../components/StatusBadge.astro'
import FitBadge from '../../components/FitBadge.astro'
import { supabase } from '../../lib/supabase.js'

const { id } = Astro.params

const { data: lead, error } = await supabase
  .from('leads')
  .select('*, lead_contacts(*, enriched_organizations(*)), lead_notes(*, id, created_at, author, text), agent_updates(*), lead_feedback(*)')
  .eq('id', id)
  .single()

if (error || !lead) {
  return Astro.redirect('/leads')
}

const notes = (lead.lead_notes || []).sort((a: any, b: any) =>
  new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
)

const feedbackHistory = (lead.lead_feedback || []).sort((a: any, b: any) =>
  new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
)

// Merged activity stream for the right-rail Notes card. Feedback entries and
// notes share a chronological view so Tom sees his "why I marked this lost"
// reasoning in-line with other updates. Each item carries a _kind discriminator
// so the template can pick the right treatment.
type ActivityItem = {
  _kind: 'note' | 'feedback'
  created_at: string
  // note fields
  author?: string
  text?: string
  // feedback fields
  sentiment?: string
  category?: string
  reasoning?: string
  status_at_feedback?: string
  generalize?: boolean
}
const activityItems: ActivityItem[] = [
  ...notes.map((n: any) => ({ _kind: 'note' as const, ...n })),
  ...feedbackHistory.map((f: any) => ({ _kind: 'feedback' as const, ...f })),
].sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())

// Categories kept in sync with the Opus calibration prompt. Labels are
// human-readable; keys are persisted in lead_feedback.category.
const negativeCategories: Array<[string, string]> = [
  ['too-large', 'Too large — beyond our scale'],
  ['too-small', 'Too small — below our threshold'],
  ['wrong-sector', 'Wrong sector / project type'],
  ['wrong-geography', 'Wrong geography / submarket'],
  ['wrong-timing', 'Bad timing (too early or already awarded)'],
  ['gc-locked-in', 'GC already locked in'],
  ['competitor-incumbent', 'Relationship conflict / competitor incumbent'],
  ['low-margin', 'Low margin / commodity work'],
  ['other-negative', 'Other — see comment'],
]
const positiveCategories: Array<[string, string]> = [
  ['great-fit', 'Great fit — sweet spot'],
  ['strong-developer', 'Strong developer / relationship'],
  ['ideal-scale', 'Ideal scale / value'],
  ['good-timing', 'Good timing — actionable now'],
  ['relationship-advantage', 'Relationship advantage / warm intro'],
  ['other-positive', 'Other — see comment'],
]
const categoryLabel: Record<string, string> = Object.fromEntries([
  ...negativeCategories,
  ...positiveCategories,
])

// Split lead_contacts into people vs organizations. entity_type='organization'
// rows are firms tracked manually on this lead; everything else is a person.
// Legacy rows with NULL entity_type are treated as people.
const allContacts = lead.lead_contacts || []
const people = allContacts.filter((c: any) => !c.entity_type || c.entity_type === 'person')
const orgContacts = allContacts.filter((c: any) => c.entity_type === 'organization')

// Group contacts by auto-enriched organization for the Firm Background panel.
// Contacts without an org_id (e.g. manually-added or named-from-article)
// don't appear here — they're listed in the Contacts section below.
const contactsByOrg: Map<string, { org: any; contacts: any[] }> = new Map()
for (const c of allContacts) {
  if (!c.enriched_organizations) continue
  const key = c.enriched_organizations.id
  if (!contactsByOrg.has(key)) {
    contactsByOrg.set(key, { org: c.enriched_organizations, contacts: [] })
  }
  contactsByOrg.get(key)!.contacts.push(c)
}
const enrichedOrgs = Array.from(contactsByOrg.values())

// Pull the latest enrichment-agent note (warm-intro angle, firm summary)
const enrichmentNote = notes.find((n: any) => n.author === 'enrichment-agent')

const statuses = ['new', 'tracking', 'pursuing', 'market-intel', 'won', 'lost', 'no-bid', 'dismissed', 'archived']
const statusLabels: Record<string, string> = {
  'market-intel': 'Market Intel',
  'no-bid': 'No-bid',
  'archived': 'Archived',
}

// Status action bar clusters. Each cluster filters out the lead's current
// status so the active state isn't shown as a destination option.
const activeStatuses = ['new', 'tracking', 'pursuing', 'market-intel'].filter(s => s !== lead.status)
const outcomeStatuses = ['won', 'lost', 'no-bid'].filter(s => s !== lead.status)
const archiveStatuses = ['dismissed', 'archived'].filter(s => s !== lead.status)
const outcomeBtnStyle: Record<string, string> = {
  'won': 'padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #A7F3D0; background: #ECFDF5; cursor: pointer; color: #065F46;',
  'lost': 'padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #FECACA; background: #FEF2F2; cursor: pointer; color: #991B1B;',
  'no-bid': 'padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #FECACA; background: #FEF2F2; cursor: pointer; color: #991B1B;',
}
---

<Layout title={lead.project_name} wide={true}>
  <a href="/leads" class="btn-ghost-custom" style="margin-bottom: 16px;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    Back to Pipeline
  </a>

  <!-- Header -->
  <div class="card-surface" style="padding: 24px; margin-bottom: 20px;">
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 200px;">
        <h1 style="font-size: 20px; font-weight: 700; color: #111827; margin-bottom: 4px; line-height: 1.4;">{lead.project_name}</h1>
        <p class="text-secondary">{lead.address}</p>
      </div>
      <div style="display: flex; align-items: center; gap: 10px; flex-shrink: 0;">
        <ScoreBadge score={lead.actionability_score || 0} />
        <StatusBadge status={lead.status} />
        {lead.fit_type && <FitBadge fitType={lead.fit_type} />}
      </div>
    </div>

    <!-- Status change buttons — grouped: Active · Outcome · Archive -->
    <div
      role="group"
      aria-label="Change status"
      style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #E5E7EB; display: flex; gap: 12px; flex-wrap: wrap; align-items: center;"
    >
      <span style="font-size: 12px; color: #9CA3AF; align-self: center;">Change status:</span>

      {activeStatuses.length > 0 && (
        <div style="display: inline-flex; gap: 6px;">
          {activeStatuses.map(s => (
            <button
              class="status-change-btn status-btn-active"
              data-lead-id={lead.id}
              data-status={s}
              style="padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #D1D5DB; background: white; cursor: pointer; color: #374151;"
            >
              {statusLabels[s] || (s.charAt(0).toUpperCase() + s.slice(1))}
            </button>
          ))}
        </div>
      )}

      {activeStatuses.length > 0 && outcomeStatuses.length > 0 && (
        <span aria-hidden="true" style="width: 1px; height: 20px; background: #E5E7EB;"></span>
      )}

      {outcomeStatuses.length > 0 && (
        <div style="display: inline-flex; gap: 6px;">
          {outcomeStatuses.map(s => (
            <button
              class="status-change-btn status-btn-outcome"
              data-lead-id={lead.id}
              data-status={s}
              style={outcomeBtnStyle[s]}
            >
              {statusLabels[s] || (s.charAt(0).toUpperCase() + s.slice(1))}
            </button>
          ))}
        </div>
      )}

      {outcomeStatuses.length > 0 && archiveStatuses.length > 0 && (
        <span aria-hidden="true" style="width: 1px; height: 20px; background: #E5E7EB;"></span>
      )}

      {archiveStatuses.length > 0 && (
        <div style="display: inline-flex; gap: 6px;">
          {archiveStatuses.map(s => (
            <button
              class="status-change-btn status-btn-archive"
              data-lead-id={lead.id}
              data-status={s}
              style="padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #E5E7EB; background: #F9FAFB; cursor: pointer; color: #6B7280;"
            >
              {statusLabels[s] || (s.charAt(0).toUpperCase() + s.slice(1))}
            </button>
          ))}
        </div>
      )}

      <button
        id="standalone-feedback-btn"
        data-lead-id={lead.id}
        style="margin-left: auto; padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: 1px solid #C7D2FE; background: #EEF2FF; cursor: pointer; color: #3730A3;"
      >
        + Add Feedback
      </button>
    </div>

    <!-- Editable score -->
    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #E5E7EB; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
      <span style="font-size: 12px; color: #9CA3AF;">Score (0–10):</span>
      <input
        type="number"
        id="score-input"
        data-lead-id={lead.id}
        min="0"
        max="10"
        step="1"
        value={lead.actionability_score ?? 0}
        style="width: 72px; padding: 4px 8px; font-size: 14px; font-weight: 600; border: 1px solid #D1D5DB; border-radius: 6px; color: #111827; text-align: center;"
      />
      <span id="score-save-status" style="font-size: 12px; color: #9CA3AF;"></span>
    </div>

    <!-- Enrichment status -->
    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #E5E7EB; display: flex; align-items: center; gap: 10px; font-size: 12px; flex-wrap: wrap;">
      <span style="color: #9CA3AF;">Enrichment:</span>
      {lead.enrichment_status === 'done' && (
        <span style="color: #065F46; font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          Done
          {lead.enriched_at && <span style="color: #9CA3AF; font-weight: 400;"> · {new Date(lead.enriched_at).toLocaleDateString()}</span>}
        </span>
      )}
      {lead.enrichment_status === 'pending' && (
        <span style="color: #92400E; font-weight: 600;">⏳ In queue</span>
      )}
      {lead.enrichment_status === 'failed' && (
        <span style="color: #991B1B; font-weight: 600;">⚠ Failed — will retry on next run</span>
      )}
      {!lead.enrichment_status && (lead.actionability_score || 0) >= 8 && (
        <span style="color: #6B7280;">Queued for next daily run</span>
      )}
      {!lead.enrichment_status && (lead.actionability_score || 0) < 8 && (
        <span style="color: #9CA3AF;">Below threshold (score ≥ 8 auto-enriches)</span>
      )}
      <button id="reenrich-btn" data-lead-id={lead.id} style="margin-left: auto; font-size: 11px; padding: 3px 10px; background: white; border: 1px solid #D1D5DB; border-radius: 6px; cursor: pointer; color: #4A6FA5;">
        Re-enrich on next run
      </button>
    </div>

    {/* Fact strip — most-glanced facts, above the fold */}
    <div class="fact-strip" style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #E5E7EB; display: grid; grid-template-columns: repeat(6, 1fr); gap: 0;">
      {[
        { label: 'Est Value', value: lead.estimated_value || '—' },
        { label: 'Stage', value: lead.stage || '—' },
        { label: 'Bid Due', value: lead.bid_due_date ? new Date(lead.bid_due_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' }) : '—' },
        { label: 'Est Start', value: lead.estimated_start_date ? new Date(lead.estimated_start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' }) : '—' },
        { label: 'GC', value: lead.gc_assigned ? (lead.gc_name || 'Assigned') : 'None' },
        { label: 'Priority', value: lead.priority || '—' },
      ].map((cell, i, arr) => (
        <div style={`padding: 0 16px; ${i < arr.length - 1 ? 'border-right: 1px solid #F3F4F6;' : ''}`}>
          <div style="font-size: 11px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">{cell.label}</div>
          <div style="font-size: 14px; font-weight: 600; color: #111827;">{cell.value}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="lead-main-grid" style="display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 16px; margin-bottom: 20px;">
    <!-- Analysis & Action (wide left column) -->
    <div class="card-surface" style="padding: 24px;">
      {lead.action_item && (
        <div style="padding: 14px; background: #FFFBEB; border: 1px solid #FDE68A; border-radius: 8px; margin-bottom: 16px;">
          <div style="font-size: 12px; font-weight: 700; color: #92400E; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Next Action</div>
          <div style="font-size: 14px; color: #92400E; line-height: 1.5;">{lead.action_item}</div>
        </div>
      )}

      <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin-bottom: 12px;">Analysis</h2>
      {lead.why_it_matters ? (
        <div style="font-size: 14px; color: #374151; line-height: 1.7;">
          {lead.why_it_matters.split('\n\n').map((para: string) => {
            if (para.startsWith('PITCH:')) {
              return (
                <div style="margin-top: 12px; padding: 12px; background: #EEF2FF; border: 1px solid #C7D2FE; border-radius: 8px;">
                  <div style="font-size: 12px; font-weight: 700; color: #3730A3; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.05em;">Pitch Angle</div>
                  <div style="font-size: 14px; color: #3730A3;">{para.replace('PITCH: ', '')}</div>
                </div>
              )
            }
            return <p style="margin: 8px 0;">{para}</p>
          })}
        </div>
      ) : (
        <p style="font-size: 14px; color: #9CA3AF;">No analysis available yet.</p>
      )}

      {lead.enrichment_needed && lead.enrichment_needed.length > 0 && (
        <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid #E5E7EB;">
          <div style="font-size: 12px; font-weight: 600; color: #6B7280; margin-bottom: 6px;">Still Needed</div>
          <div style="display: flex; gap: 4px; flex-wrap: wrap;">
            {lead.enrichment_needed.map((e: string) => (
              <span style="font-size: 11px; background: #F3F4F6; color: #6B7280; padding: 3px 10px; border-radius: 999px;">{e}</span>
            ))}
          </div>
        </div>
      )}

      {lead.source_url && (
        <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid #E5E7EB;">
          <a href={lead.source_url} target="_blank" rel="noopener" style="font-size: 13px; color: #4A6FA5; text-decoration: underline; display: inline-flex; align-items: center; gap: 4px;">
            View original source
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      )}
    </div>

    <!-- Right rail: Notes (top, sticky) + Project Meta (below) -->
    <div style="display: flex; flex-direction: column; gap: 16px; min-width: 0;">
      <!-- Notes & Activity -->
      <div class="card-surface" style="padding: 20px;">
        <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin-bottom: 12px;">Notes & Activity</h2>

        <form id="add-note-form" style="margin-bottom: 16px; display: flex; gap: 6px;">
          <input type="hidden" id="note-lead-id" value={lead.id} />
          <input type="text" id="note-text" class="form-input" placeholder="Add a note..." style="flex: 1; min-width: 0; padding: 8px 12px; font-size: 13px;" />
          <button type="submit" class="btn-primary-custom" style="padding: 8px 14px; font-size: 13px; flex-shrink: 0;">Add</button>
        </form>

        <div id="notes-list" style="max-height: 420px; overflow-y: auto;">
          {activityItems.length === 0 ? (
            <p class="text-secondary" style="font-size: 13px;">No notes yet. Add one above.</p>
          ) : (
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {activityItems.map((item) => item._kind === 'note' ? (
                <div style="padding: 10px 12px; background: #F9FAFB; border-radius: 8px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 4px; gap: 8px;">
                    <span style="font-size: 11px; font-weight: 600; color: #6B7280;">{item.author}</span>
                    <span style="font-size: 11px; color: #9CA3AF; flex-shrink: 0;">{new Date(item.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                  </div>
                  <div style="font-size: 13px; color: #374151; line-height: 1.5; word-wrap: break-word;">{item.text}</div>
                </div>
              ) : (
                <div style={`padding: 10px 12px; background: ${item.sentiment === 'positive' ? '#F0FDF4' : '#FEF2F2'}; border-left: 3px solid ${item.sentiment === 'positive' ? '#10B981' : '#EF4444'}; border-radius: 8px;`}>
                  <div style="display: flex; justify-content: space-between; margin-bottom: 6px; gap: 8px; flex-wrap: wrap;">
                    <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                      <span style={`font-size: 10px; padding: 1px 8px; background: ${item.sentiment === 'positive' ? '#ECFDF5' : '#FEF2F2'}; color: ${item.sentiment === 'positive' ? '#065F46' : '#991B1B'}; border: 1px solid ${item.sentiment === 'positive' ? '#A7F3D0' : '#FECACA'}; border-radius: 999px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;`}>
                        {item.sentiment === 'positive' ? 'Liked' : 'Rejected'}
                      </span>
                      <span style="font-size: 12px; font-weight: 600; color: #111827;">{item.category ? (categoryLabel[item.category] || item.category) : ''}</span>
                    </div>
                    <span style="font-size: 11px; color: #9CA3AF; flex-shrink: 0;">{new Date(item.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                  </div>
                  {item.reasoning && (
                    <div style="font-size: 13px; color: #374151; line-height: 1.5; word-wrap: break-word;">{item.reasoning}</div>
                  )}
                  {item.status_at_feedback && (
                    <div style="font-size: 10px; color: #9CA3AF; margin-top: 4px;">on move to: {item.status_at_feedback}</div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Project Meta -->
      <div class="card-surface" style="padding: 20px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
          <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin: 0;">Project Meta</h2>
          <span id="meta-save-status" style="font-size: 11px; color: #9CA3AF;"></span>
        </div>
        <dl style="display: grid; grid-template-columns: auto 1fr; gap: 6px 12px; font-size: 13px; align-items: center;">
          {/* Editable fields — Tom updates these as the lead progresses */}
          <dt style="color: #6B7280; font-weight: 500;">Stage</dt>
          <dd>
            <input
              class="inline-edit-input"
              type="text"
              data-lead-id={lead.id}
              data-field="stage"
              value={lead.stage || ''}
              placeholder="planning, permitted…"
              style="width: 100%;"
            />
          </dd>

          <dt style="color: #6B7280; font-weight: 500;">Priority</dt>
          <dd>
            <select
              class="inline-edit-input inline-edit-select"
              data-lead-id={lead.id}
              data-field="priority"
              style="width: 100%;"
            >
              {['', 'high', 'medium', 'low'].map(p => (
                <option value={p} selected={(lead.priority || '') === p}>{p || '—'}</option>
              ))}
            </select>
          </dd>

          <dt style="color: #6B7280; font-weight: 500;">Bid Due</dt>
          <dd>
            <input
              class="inline-edit-input"
              type="date"
              data-lead-id={lead.id}
              data-field="bid_due_date"
              value={lead.bid_due_date || ''}
              style="width: 100%;"
            />
          </dd>

          <dt style="color: #6B7280; font-weight: 500;">Est Start</dt>
          <dd>
            <input
              class="inline-edit-input"
              type="date"
              data-lead-id={lead.id}
              data-field="estimated_start_date"
              value={lead.estimated_start_date || ''}
              style="width: 100%;"
            />
          </dd>

          <dt style="color: #6B7280; font-weight: 500;">Next Action</dt>
          <dd>
            <input
              class="inline-edit-input"
              type="date"
              data-lead-id={lead.id}
              data-field="next_action_date"
              value={lead.next_action_date || ''}
              style="width: 100%;"
            />
          </dd>

          <dt style="color: #6B7280; font-weight: 500;">Assigned To</dt>
          <dd>
            <input
              class="inline-edit-input"
              type="text"
              data-lead-id={lead.id}
              data-field="assigned_to"
              value={lead.assigned_to || ''}
              placeholder="Tom Keilty"
              style="width: 100%;"
            />
          </dd>

          {/* Read-only reference fields — stamps from ingestion */}
          <dt style="color: #6B7280; font-weight: 500; padding-top: 8px; border-top: 1px solid #F3F4F6;">Type</dt>
          <dd style="color: #111827; padding-top: 8px; border-top: 1px solid #F3F4F6;">{lead.project_type || '—'}</dd>
          <dt style="color: #6B7280; font-weight: 500;">Source</dt>
          <dd style="color: #111827;">
            {lead.source_url ? (
              <a href={lead.source_url} target="_blank" rel="noopener" style="color: #4A6FA5; text-decoration: underline; display: inline-flex; align-items: center; gap: 4px;">
                {lead.source_name || lead.source_type}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            ) : (
              <span>
                {lead.source_name || lead.source_type}
                {' '}
                <a href={`https://www.google.com/search?q=${encodeURIComponent(lead.project_name + ' Arizona construction')}`} target="_blank" rel="noopener" style="font-size: 11px; color: #4A6FA5; text-decoration: underline;">search ↗</a>
              </span>
            )}
          </dd>
          <dt style="color: #6B7280; font-weight: 500;">Source Date</dt>
          <dd style="color: #111827;">{lead.briefing_date ? new Date(lead.briefing_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—'}</dd>
          <dt style="color: #6B7280; font-weight: 500;">First Seen</dt>
          <dd style="color: #111827;">{new Date(lead.first_seen_at || lead.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</dd>
          {lead.permit_number && (<><dt style="color: #6B7280; font-weight: 500;">Permit #</dt><dd style="color: #111827;">{lead.permit_number}</dd></>)}
          {lead.referral_from && (<><dt style="color: #6B7280; font-weight: 500;">Referral</dt><dd style="color: #111827;">{lead.referral_from}</dd></>)}
        </dl>

        {(lead.status === 'won' || lead.status === 'lost' || lead.status === 'no-bid') && (lead.contract_value || lead.lost_to || lead.lost_reason) && (
          <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid #E5E7EB;">
            <div style="font-size: 11px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Outcome</div>
            <dl style="display: grid; grid-template-columns: auto 1fr; gap: 6px 12px; font-size: 13px;">
              {lead.contract_value && (<><dt style="color: #6B7280; font-weight: 500;">Contract</dt><dd style="color: #065F46; font-weight: 600;">{lead.contract_value}</dd></>)}
              {lead.lost_to && (<><dt style="color: #6B7280; font-weight: 500;">Lost To</dt><dd style="color: #991B1B;">{lead.lost_to}</dd></>)}
              {lead.lost_reason && (<><dt style="color: #6B7280; font-weight: 500;">Reason</dt><dd style="color: #374151;">{lead.lost_reason}</dd></>)}
            </dl>
          </div>
        )}
      </div>
    </div>
  </div>

  {(enrichedOrgs.length > 0 || enrichmentNote) && (
    <div class="card-surface" style="padding: 24px; margin-bottom: 20px;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
        <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin: 0;">Firm Background</h2>
        <span style="font-size: 11px; padding: 2px 8px; background: #ECFDF5; color: #065F46; border-radius: 999px; font-weight: 600;">AUTO-ENRICHED</span>
      </div>

      {enrichmentNote && (
        <div style="margin-bottom: 16px; padding: 12px; background: #F9FAFB; border-left: 3px solid #10B981; border-radius: 6px; font-size: 13px; color: #374151; line-height: 1.7; white-space: pre-line;">{enrichmentNote.text}</div>
      )}

      {enrichedOrgs.length > 0 && (
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {enrichedOrgs.map(({ org, contacts }) => (
            <div style="padding: 14px; border: 1px solid #E5E7EB; border-radius: 8px;">
              <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; flex-wrap: wrap;">
                <span style="font-size: 14px; font-weight: 700; color: #111827;">{org.display_name}</span>
                {org.org_type && <span style="font-size: 11px; padding: 1px 8px; background: #EEF2FF; color: #3730A3; border-radius: 999px; font-weight: 600; text-transform: capitalize;">{org.org_type}</span>}
                {org.website && <a href={org.website} target="_blank" rel="noopener" style="font-size: 11px; color: #4A6FA5; text-decoration: underline;">website ↗</a>}
                {org.linkedin_url && <a href={org.linkedin_url} target="_blank" rel="noopener" style="font-size: 11px; color: #0A66C2; text-decoration: underline;">LinkedIn ↗</a>}
              </div>

              <div style="font-size: 12px; color: #6B7280; margin-bottom: 10px;">
                {[
                  org.hq_city && org.hq_state ? `${org.hq_city}, ${org.hq_state}` : org.hq_city || org.hq_state,
                  org.employee_count ? `~${org.employee_count} employees` : null,
                  org.industry,
                  org.founded_year ? `est. ${org.founded_year}` : null
                ].filter(Boolean).join(' · ') || 'No firmographic data'}
              </div>

              {contacts.length > 0 && (
                <div style="display: flex; flex-direction: column; gap: 6px;">
                  <div style="font-size: 11px; font-weight: 600; color: #6B7280; text-transform: uppercase; letter-spacing: 0.04em;">Decision Makers</div>
                  {contacts.map((c: any) => (
                    <div style="display: flex; align-items: center; gap: 10px; font-size: 13px;">
                      <div style="flex: 1;">
                        <span style="font-weight: 600; color: #111827;">{c.name}</span>
                        {c.role && <span style="color: #6B7280;"> · {c.role}</span>}
                      </div>
                      <div style="display: flex; gap: 6px;">
                        {c.phone && (
                          <a href={`tel:${c.phone}`} style="font-size: 12px; color: #4A6FA5; text-decoration: none; padding: 2px 8px; background: #EFF6FF; border-radius: 4px;" title={c.phone}>📞 {c.phone}</a>
                        )}
                        {c.email && (
                          <a href={`mailto:${c.email}`} style="font-size: 12px; color: #4A6FA5; text-decoration: none; padding: 2px 8px; background: #EFF6FF; border-radius: 4px;" title={c.email}>✉ Email</a>
                        )}
                        {c.notes && c.notes.includes('LinkedIn:') && (
                          <a href={c.notes.replace('LinkedIn: ', '')} target="_blank" rel="noopener" style="font-size: 12px; color: #0A66C2; text-decoration: none; padding: 2px 8px; background: #EFF6FF; border-radius: 4px;">in</a>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- Outreach Generator — compact row until generated, then expands via JS state -->
  <div class="card-surface" style="padding: 16px 20px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
      <div>
        <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin: 0;">Outreach Generator</h2>
        <p style="font-size: 12px; color: #9CA3AF; margin: 2px 0 0;">Drafts a personalized email and LinkedIn message from deep research on this project.</p>
      </div>
      <button type="button" id="generate-outreach-btn" class="btn-primary-custom" style="padding: 8px 16px; font-size: 13px; flex-shrink: 0;" data-lead-json={JSON.stringify({
        project_name: lead.project_name,
        address: lead.address,
        project_type: lead.project_type,
        estimated_value: lead.estimated_value,
        stage: lead.stage,
        gc_assigned: lead.gc_assigned,
        gc_name: lead.gc_name,
        fit_type: lead.fit_type,
        source_name: lead.source_name,
        source_type: lead.source_type,
        why_it_matters: lead.why_it_matters,
        action_item: lead.action_item,
      })}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Draft Outreach
      </button>
    </div>

    {lead.lead_contacts && lead.lead_contacts.length > 0 && (
      <div style="margin-top: 12px;">
        <label class="form-label" for="outreach-contact-select">Target contact (optional)</label>
        <select id="outreach-contact-select" class="form-input" style="max-width: 300px;">
          <option value="">General outreach (no specific contact)</option>
          {lead.lead_contacts.map((c: any) => (
            <option value={JSON.stringify({ name: c.name, role: c.role, company: c.company })}>{c.name}{c.role ? ` — ${c.role}` : ''}</option>
          ))}
        </select>
      </div>
    )}

    <div id="outreach-loading" style="display: none; padding: 24px; text-align: center;">
      <div style="font-size: 14px; color: #6B7280;">Researching project and drafting outreach...</div>
      <div style="font-size: 12px; color: #9CA3AF; margin-top: 4px;">This takes 15–30 seconds</div>
    </div>

    <div id="outreach-error" style="display: none; padding: 14px; background: #FEF2F2; border: 1px solid #FECACA; border-radius: 8px; color: #991B1B; font-size: 14px; margin-bottom: 12px;"></div>

    <div id="outreach-results" style="display: none; margin-top: 16px;">
      <!-- Research -->
      <div style="margin-bottom: 16px;">
        <div style="font-size: 12px; font-weight: 700; color: #065F46; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Research Summary</div>
        <div id="outreach-research" style="font-size: 14px; color: #374151; line-height: 1.7; padding: 12px; background: #ECFDF5; border: 1px solid #A7F3D0; border-radius: 8px; white-space: pre-line;"></div>
      </div>

      <!-- Email -->
      <div style="margin-bottom: 16px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
          <div style="font-size: 12px; font-weight: 700; color: #1E40AF; text-transform: uppercase; letter-spacing: 0.05em;">Email Draft</div>
          <button type="button" class="copy-btn" data-target="outreach-email-body" style="font-size: 11px; color: #4A6FA5; background: #EEF2FF; border: 1px solid #C7D2FE; padding: 3px 10px; border-radius: 6px; cursor: pointer;">Copy</button>
        </div>
        <div style="padding: 14px; background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 8px;">
          <div style="font-size: 13px; font-weight: 600; color: #1E40AF; margin-bottom: 8px;">Subject: <span id="outreach-email-subject"></span></div>
          <div id="outreach-email-body" style="font-size: 14px; color: #1E3A5F; line-height: 1.7; white-space: pre-line;"></div>
        </div>
      </div>

      <!-- LinkedIn -->
      <div>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
          <div style="font-size: 12px; font-weight: 700; color: #0A66C2; text-transform: uppercase; letter-spacing: 0.05em;">LinkedIn Message</div>
          <button type="button" class="copy-btn" data-target="outreach-linkedin" style="font-size: 11px; color: #4A6FA5; background: #EEF2FF; border: 1px solid #C7D2FE; padding: 3px 10px; border-radius: 6px; cursor: pointer;">Copy</button>
        </div>
        <div id="outreach-linkedin" style="font-size: 14px; color: #374151; line-height: 1.7; padding: 14px; background: #F0F7FF; border: 1px solid #BFDBFE; border-radius: 8px; white-space: pre-line;"></div>
      </div>
    </div>

    <div id="outreach-empty" style="display: none;"></div>
  </div>

  <!-- Contacts (people) -->
  <div class="card-surface" style="padding: 20px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
      <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin: 0;">Contacts</h2>
      <button type="button" id="toggle-contact-form" style="font-size: 13px; color: #4A6FA5; background: none; border: none; cursor: pointer; font-weight: 500;">+ Add Contact</button>
    </div>

    <!-- Add contact form (hidden by default) -->
    <form id="add-contact-form" style="display: none; margin-bottom: 20px; padding: 16px; background: #F9FAFB; border-radius: 8px; border: 1px solid #E5E7EB;">
      <input type="hidden" id="contact-lead-id" value={lead.id} />
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <label class="form-label" for="contact-name">Name *</label>
          <input type="text" id="contact-name" class="form-input" required placeholder="Jane Smith" />
        </div>
        <div>
          <label class="form-label" for="contact-role">Role</label>
          <select id="contact-role" class="form-input">
            <option value="">Select...</option>
            <option value="Developer">Developer</option>
            <option value="Owner">Owner / Owner's Rep</option>
            <option value="Architect">Architect</option>
            <option value="GC">General Contractor</option>
            <option value="Engineer">Engineer</option>
            <option value="Subcontractor">Subcontractor</option>
            <option value="Broker">Broker</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <label class="form-label" for="contact-company">Organization</label>
          <input type="text" id="contact-company" class="form-input" placeholder="Firm / organization name" />
        </div>
        <div>
          <label class="form-label" for="contact-phone">Phone</label>
          <input type="tel" id="contact-phone" class="form-input" placeholder="480-555-1234" />
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <label class="form-label" for="contact-email">Email</label>
          <input type="email" id="contact-email" class="form-input" placeholder="jane@example.com" />
        </div>
        <div>
          <label class="form-label" for="contact-notes">Notes</label>
          <input type="text" id="contact-notes" class="form-input" placeholder="Met at project site" />
        </div>
      </div>
      <div style="display: flex; gap: 8px;">
        <button type="submit" class="btn-primary-custom" style="padding: 8px 16px; font-size: 13px;" id="save-contact-btn">Save Contact</button>
        <button type="button" id="cancel-contact" class="btn-ghost-custom" style="padding: 8px 16px; font-size: 13px;">Cancel</button>
      </div>
    </form>

    {people.length > 0 ? (
      <div style="display: flex; flex-direction: column; gap: 4px;" id="contacts-list">
        {people.map((c: any) => (
          <div class="contact-row" data-contact-id={c.id} data-lead-id={lead.id} data-entity-type="person"
               data-name={c.name || ''} data-role={c.role || ''} data-company={c.company || ''}
               data-phone={c.phone || ''} data-email={c.email || ''} data-notes={c.notes || ''}>
            <div class="contact-view" style="display: flex; gap: 12px; align-items: center; padding: 10px 0; border-bottom: 1px solid #F3F4F6; cursor: pointer;">
              <div style="width: 32px; height: 32px; background: #E5E7EB; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #6B7280; flex-shrink: 0;">{c.name?.charAt(0) || '?'}</div>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 14px; font-weight: 500; color: #111827;">{c.name}</div>
                <div style="font-size: 12px; color: #9CA3AF;">{[c.role, c.company].filter(Boolean).join(' · ')}</div>
              </div>
              <div style="display: flex; gap: 8px; flex-shrink: 0; align-items: center;">
                {c.phone && (
                  <a href={`tel:${c.phone}`} onclick="event.stopPropagation()" style="font-size: 12px; color: #4A6FA5; text-decoration: none;" title={c.phone}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </a>
                )}
                {c.email && (
                  <a href={`mailto:${c.email}`} onclick="event.stopPropagation()" style="font-size: 12px; color: #4A6FA5; text-decoration: none;" title={c.email}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </a>
                )}
                <span style="font-size: 11px; color: #9CA3AF;">edit ✎</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-muted" id="no-contacts-msg" style="font-size: 12px; margin: 0;">No contacts yet — use “+ Add Contact” above.</p>
    )}
  </div>

  <!-- Organizations (firms) -->
  <div class="card-surface" style="padding: 24px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
      <h2 style="font-size: 15px; font-weight: 600; color: #111827;">Organizations</h2>
      <button type="button" id="toggle-org-form" style="font-size: 13px; color: #4A6FA5; background: none; border: none; cursor: pointer; font-weight: 500;">+ Add Organization</button>
    </div>

    <form id="add-org-form" style="display: none; margin-bottom: 20px; padding: 16px; background: #F9FAFB; border-radius: 8px; border: 1px solid #E5E7EB;">
      <input type="hidden" id="org-lead-id" value={lead.id} />
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <label class="form-label" for="org-name">Organization Name *</label>
          <input type="text" id="org-name" class="form-input" required placeholder="e.g. Sundt Construction" />
        </div>
        <div>
          <label class="form-label" for="org-role">Type</label>
          <select id="org-role" class="form-input">
            <option value="">Select...</option>
            <option value="Developer">Developer</option>
            <option value="Owner">Owner</option>
            <option value="Architect">Architect</option>
            <option value="GC">General Contractor</option>
            <option value="Engineer">Engineer</option>
            <option value="Subcontractor">Subcontractor</option>
            <option value="Broker">Broker</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <label class="form-label" for="org-website">Website</label>
          <input type="text" id="org-website" class="form-input" placeholder="https://example.com" />
        </div>
        <div>
          <label class="form-label" for="org-phone">Phone</label>
          <input type="tel" id="org-phone" class="form-input" placeholder="480-555-1234" />
        </div>
      </div>
      <div style="margin-bottom: 12px;">
        <label class="form-label" for="org-notes">Notes</label>
        <input type="text" id="org-notes" class="form-input" placeholder="Relationship / context" />
      </div>
      <div style="display: flex; gap: 8px;">
        <button type="submit" class="btn-primary-custom" style="padding: 8px 16px; font-size: 13px;" id="save-org-btn">Save Organization</button>
        <button type="button" id="cancel-org" class="btn-ghost-custom" style="padding: 8px 16px; font-size: 13px;">Cancel</button>
      </div>
    </form>

    {orgContacts.length > 0 ? (
      <div style="display: flex; flex-direction: column; gap: 4px;" id="orgs-list">
        {orgContacts.map((c: any) => {
          // Website stored in the notes field as "Website: <url>" when
          // captured via the Organizations form; split back out for display.
          const notesStr = c.notes || ''
          const webMatch = notesStr.match(/^Website:\s*(\S+)\s*(?:—\s*)?(.*)$/s)
          const website = webMatch ? webMatch[1] : ''
          const noteRest = webMatch ? webMatch[2].trim() : notesStr
          return (
            <div class="org-row" data-contact-id={c.id} data-lead-id={lead.id} data-entity-type="organization"
                 data-name={c.name || ''} data-role={c.role || ''} data-company={c.company || ''}
                 data-phone={c.phone || ''} data-email={c.email || ''} data-notes={c.notes || ''}
                 data-website={website} data-note-rest={noteRest}>
              <div class="org-view" style="display: flex; gap: 12px; align-items: center; padding: 10px 0; border-bottom: 1px solid #F3F4F6; cursor: pointer;">
                <div style="width: 32px; height: 32px; background: #EEF2FF; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #3730A3; flex-shrink: 0;">🏢</div>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 14px; font-weight: 500; color: #111827;">{c.name}</div>
                  <div style="font-size: 12px; color: #9CA3AF;">{[c.role, noteRest || null].filter(Boolean).join(' · ') || '—'}</div>
                </div>
                <div style="display: flex; gap: 8px; flex-shrink: 0; align-items: center;">
                  {website && (
                    <a href={website.startsWith('http') ? website : `https://${website}`} target="_blank" rel="noopener" onclick="event.stopPropagation()" style="font-size: 11px; color: #4A6FA5; text-decoration: underline;">website ↗</a>
                  )}
                  {c.phone && (
                    <a href={`tel:${c.phone}`} onclick="event.stopPropagation()" style="font-size: 12px; color: #4A6FA5; text-decoration: none;" title={c.phone}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </a>
                  )}
                  <span style="font-size: 11px; color: #9CA3AF;">edit ✎</span>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    ) : (
      <p class="text-secondary">No organizations added yet. Track firms (developers, GCs, architects) involved in this project.</p>
    )}
  </div>

  <!-- Edit Contact / Organization Modal — opened by clicking any contact or org row -->
  <div id="edit-entity-modal" data-lead-id={lead.id} style="display: none; position: fixed; inset: 0; background: rgba(17, 24, 39, 0.5); z-index: 100; align-items: center; justify-content: center; padding: 16px;">
    <div style="background: white; border-radius: 12px; max-width: 560px; width: 100%; padding: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); max-height: 90vh; overflow-y: auto;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 id="edit-entity-title" style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Edit Contact</h3>
        <button type="button" id="edit-entity-close" style="background: none; border: none; cursor: pointer; font-size: 22px; color: #9CA3AF; line-height: 1;">&times;</button>
      </div>

      <form id="edit-entity-form">
        <input type="hidden" id="edit-entity-id" />
        <input type="hidden" id="edit-entity-type" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
          <div>
            <label class="form-label" for="edit-entity-name"><span id="edit-name-label">Name</span> *</label>
            <input type="text" id="edit-entity-name" class="form-input" required />
          </div>
          <div>
            <label class="form-label" for="edit-entity-role"><span id="edit-role-label">Role</span></label>
            <select id="edit-entity-role" class="form-input">
              <option value="">Select...</option>
              <option value="Developer">Developer</option>
              <option value="Owner">Owner</option>
              <option value="Architect">Architect</option>
              <option value="GC">General Contractor</option>
              <option value="Engineer">Engineer</option>
              <option value="Subcontractor">Subcontractor</option>
              <option value="Broker">Broker</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        <div id="edit-company-row" style="margin-bottom: 12px;">
          <label class="form-label" for="edit-entity-company">Organization</label>
          <input type="text" id="edit-entity-company" class="form-input" placeholder="Firm / organization name" />
        </div>

        <div id="edit-website-row" style="display: none; margin-bottom: 12px;">
          <label class="form-label" for="edit-entity-website">Website</label>
          <input type="text" id="edit-entity-website" class="form-input" placeholder="https://example.com" />
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
          <div>
            <label class="form-label" for="edit-entity-phone">Phone</label>
            <input type="tel" id="edit-entity-phone" class="form-input" />
          </div>
          <div>
            <label class="form-label" for="edit-entity-email">Email</label>
            <input type="email" id="edit-entity-email" class="form-input" />
          </div>
        </div>

        <div style="margin-bottom: 16px;">
          <label class="form-label" for="edit-entity-notes">Notes</label>
          <input type="text" id="edit-entity-notes" class="form-input" />
        </div>

        <div id="edit-entity-error" style="display: none; padding: 10px 12px; background: #FEF2F2; border: 1px solid #FECACA; border-radius: 8px; color: #991B1B; font-size: 13px; margin-bottom: 12px;"></div>

        <div style="display: flex; justify-content: space-between; align-items: center;">
          <button type="button" id="edit-entity-delete" style="padding: 8px 14px; font-size: 13px; background: white; border: 1px solid #FECACA; border-radius: 8px; color: #991B1B; cursor: pointer;">Delete</button>
          <div style="display: flex; gap: 8px;">
            <button type="button" id="edit-entity-cancel" class="btn-ghost-custom" style="padding: 8px 16px; font-size: 13px;">Cancel</button>
            <button type="submit" class="btn-primary-custom" style="padding: 8px 16px; font-size: 13px;" id="edit-entity-save">Save</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Feedback History — Tom's calibration on this lead, drives Opus scoring on future runs -->
  <div class="card-surface" style="padding: 24px; margin-top: 20px;">
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;">
      <h2 style="font-size: 15px; font-weight: 600; color: #111827; margin: 0;">Feedback & Calibration</h2>
      <span style="font-size: 11px; padding: 2px 8px; background: #EEF2FF; color: #3730A3; border-radius: 999px; font-weight: 600;">TRAINS OPUS</span>
    </div>

    {feedbackHistory.length === 0 ? (
      <p class="text-secondary" style="font-size: 13px;">
        No feedback yet. When you dismiss, lose, or pursue a lead, you'll be prompted for a reason. Generalizable feedback feeds the next agent run's scoring.
      </p>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 8px;">
        {feedbackHistory.map((f: any) => {
          const isPositive = f.sentiment === 'positive'
          const pillBg = isPositive ? '#ECFDF5' : '#FEF2F2'
          const pillColor = isPositive ? '#065F46' : '#991B1B'
          const pillBorder = isPositive ? '#A7F3D0' : '#FECACA'
          return (
            <div style="padding: 12px; background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 8px;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; flex-wrap: wrap; gap: 6px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                  <span style={`font-size: 11px; padding: 2px 10px; background: ${pillBg}; color: ${pillColor}; border: 1px solid ${pillBorder}; border-radius: 999px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;`}>
                    {isPositive ? 'Liked' : 'Rejected'}
                  </span>
                  <span style="font-size: 13px; font-weight: 600; color: #111827;">{categoryLabel[f.category] || f.category}</span>
                  {f.generalize && (
                    <span style="font-size: 10px; padding: 1px 8px; background: #EEF2FF; color: #3730A3; border-radius: 999px; font-weight: 600;">IN CALIBRATION</span>
                  )}
                </div>
                <span style="font-size: 12px; color: #9CA3AF;">{new Date(f.created_at).toLocaleDateString()}</span>
              </div>
              {f.reasoning && (
                <div style="font-size: 13px; color: #374151; line-height: 1.6; margin-top: 4px;">{f.reasoning}</div>
              )}
              {f.status_at_feedback && (
                <div style="font-size: 11px; color: #9CA3AF; margin-top: 4px;">Captured on move to: {f.status_at_feedback}</div>
              )}
            </div>
          )
        })}
      </div>
    )}
  </div>

  <!-- Feedback Modal — used by status transitions (dismissed/lost/no-bid/archived/pursuing/won)
       and by the standalone "+ Add Feedback" button. Hidden by default. -->
  <div
    id="feedback-modal"
    data-lead-id={lead.id}
    data-current-status={lead.status}
    style="display: none; position: fixed; inset: 0; background: rgba(17, 24, 39, 0.5); z-index: 100; align-items: center; justify-content: center; padding: 16px;"
  >
    <div style="background: white; border-radius: 12px; max-width: 520px; width: 100%; padding: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); max-height: 90vh; overflow-y: auto;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
        <h3 id="feedback-modal-title" style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Add Feedback</h3>
        <button type="button" id="feedback-modal-close" style="background: none; border: none; cursor: pointer; font-size: 22px; color: #9CA3AF; line-height: 1;">&times;</button>
      </div>
      <p id="feedback-modal-subtitle" style="font-size: 13px; color: #6B7280; margin-bottom: 16px;">Your reasoning trains the scoring model for future leads.</p>

      <form id="feedback-form">
        <!-- Sentiment (visible only in standalone mode; hidden when driven by a status transition) -->
        <div id="feedback-sentiment-wrap" style="display: none; margin-bottom: 14px;">
          <label class="form-label">This lead was…</label>
          <div style="display: flex; gap: 8px;">
            <label style="flex: 1; display: flex; align-items: center; gap: 6px; padding: 10px; border: 1px solid #E5E7EB; border-radius: 8px; cursor: pointer; font-size: 13px;">
              <input type="radio" name="feedback-sentiment" value="positive" /> Liked (pursue pattern)
            </label>
            <label style="flex: 1; display: flex; align-items: center; gap: 6px; padding: 10px; border: 1px solid #E5E7EB; border-radius: 8px; cursor: pointer; font-size: 13px;">
              <input type="radio" name="feedback-sentiment" value="negative" checked /> Rejected (avoid pattern)
            </label>
          </div>
        </div>

        <div style="margin-bottom: 14px;">
          <label class="form-label" for="feedback-category">Reason *</label>
          <select id="feedback-category" class="form-input" required>
            <option value="">Select a reason…</option>
            <!-- Options injected by JS based on sentiment -->
          </select>
        </div>

        <div style="margin-bottom: 14px;">
          <label class="form-label" for="feedback-reasoning">Why? (optional, but valuable)</label>
          <textarea id="feedback-reasoning" class="form-input" rows="3" placeholder="e.g. $90M hospital is beyond our scale; we top out around $40M on institutional work."></textarea>
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: #374151; cursor: pointer;">
            <input type="checkbox" id="feedback-generalize" checked /> Apply this reasoning to similar future leads
          </label>
          <div style="font-size: 11px; color: #9CA3AF; margin-top: 4px; margin-left: 22px;">Uncheck for one-off situations you don't want the agent to learn from.</div>
        </div>

        <div id="feedback-error" style="display: none; padding: 10px 12px; background: #FEF2F2; border: 1px solid #FECACA; border-radius: 8px; color: #991B1B; font-size: 13px; margin-bottom: 12px;"></div>

        <div style="display: flex; gap: 8px; justify-content: flex-end;">
          <button type="button" id="feedback-cancel" class="btn-ghost-custom" style="padding: 8px 16px; font-size: 13px;">Cancel</button>
          <button type="submit" id="feedback-submit" class="btn-primary-custom" style="padding: 8px 16px; font-size: 13px;">Save Feedback</button>
        </div>
      </form>
    </div>
  </div>

  {lead.source_url && (
    <div style="margin-top: 16px;">
      <a href={lead.source_url} target="_blank" rel="noopener" class="btn-ghost-custom" style="font-size: 13px;">
        View original source →
      </a>
    </div>
  )}
</Layout>

<script>
  // Editable score — save on change/blur
  const scoreInput = document.getElementById('score-input') as HTMLInputElement | null
  const scoreStatus = document.getElementById('score-save-status')
  if (scoreInput) {
    const saveScore = async () => {
      const leadId = scoreInput.dataset.leadId
      let val = parseInt(scoreInput.value, 10)
      if (!Number.isFinite(val)) val = 0
      val = Math.max(0, Math.min(10, val))
      scoreInput.value = String(val)

      if (scoreStatus) scoreStatus.textContent = 'Saving...'
      try {
        const res = await fetch(`/api/leads/${leadId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ actionability_score: val })
        })
        if (!res.ok) {
          const data = await res.json().catch(() => ({}))
          throw new Error(data.error || `Save failed (${res.status})`)
        }
        if (scoreStatus) {
          scoreStatus.textContent = 'Saved'
          scoreStatus.style.color = '#065F46'
          setTimeout(() => { if (scoreStatus) scoreStatus.textContent = '' }, 1500)
        }
      } catch (err: any) {
        if (scoreStatus) {
          scoreStatus.textContent = err?.message || 'Save failed'
          scoreStatus.style.color = '#991B1B'
        }
      }
    }
    scoreInput.addEventListener('change', saveScore)
    scoreInput.addEventListener('blur', () => {
      if (String(parseInt(scoreInput.value, 10)) !== scoreInput.dataset.lastSaved) {
        saveScore()
      }
    })
  }

  // Inline-edit for Project Meta fields — click-to-edit, save on change/blur.
  // Empty string → null so Supabase clears the field instead of storing ''.
  const metaStatus = document.getElementById('meta-save-status')
  document.querySelectorAll<HTMLInputElement | HTMLSelectElement>('.inline-edit-input').forEach((el) => {
    el.dataset.lastSaved = el.value
    const saveField = async () => {
      const field = el.dataset.field
      const leadId = el.dataset.leadId
      if (!field || !leadId) return
      const raw = el.value.trim()
      if (raw === el.dataset.lastSaved) return
      if (metaStatus) { metaStatus.textContent = 'Saving…'; metaStatus.style.color = '#9CA3AF' }
      try {
        const res = await fetch(`/api/leads/${leadId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ [field]: raw === '' ? null : raw }),
        })
        if (!res.ok) {
          const data = await res.json().catch(() => ({}))
          throw new Error(data.error || `Save failed (${res.status})`)
        }
        el.dataset.lastSaved = el.value
        if (metaStatus) {
          metaStatus.textContent = 'Saved'
          metaStatus.style.color = '#065F46'
          setTimeout(() => { if (metaStatus && metaStatus.textContent === 'Saved') metaStatus.textContent = '' }, 1500)
        }
      } catch (err: any) {
        if (metaStatus) {
          metaStatus.textContent = err?.message || 'Save failed'
          metaStatus.style.color = '#991B1B'
        }
      }
    }
    el.addEventListener('change', saveField)
    el.addEventListener('blur', saveField)
  })

  // --- Feedback modal state + helpers ---
  // Negative/positive status transitions trigger the modal (required reason
  // before status changes). The standalone "+ Add Feedback" button also
  // opens the modal but lets Tom pick sentiment manually.
  const NEGATIVE_STATUSES = new Set(['dismissed', 'lost', 'no-bid', 'archived'])
  const POSITIVE_STATUSES = new Set(['pursuing', 'won'])
  const NEGATIVE_CATEGORIES: Array<[string, string]> = [
    ['too-large', 'Too large — beyond our scale'],
    ['too-small', 'Too small — below our threshold'],
    ['wrong-sector', 'Wrong sector / project type'],
    ['wrong-geography', 'Wrong geography / submarket'],
    ['wrong-timing', 'Bad timing (too early or already awarded)'],
    ['gc-locked-in', 'GC already locked in'],
    ['competitor-incumbent', 'Relationship conflict / competitor incumbent'],
    ['low-margin', 'Low margin / commodity work'],
    ['other-negative', 'Other — see comment'],
  ]
  const POSITIVE_CATEGORIES: Array<[string, string]> = [
    ['great-fit', 'Great fit — sweet spot'],
    ['strong-developer', 'Strong developer / relationship'],
    ['ideal-scale', 'Ideal scale / value'],
    ['good-timing', 'Good timing — actionable now'],
    ['relationship-advantage', 'Relationship advantage / warm intro'],
    ['other-positive', 'Other — see comment'],
  ]

  const feedbackModal = document.getElementById('feedback-modal') as HTMLElement
  const feedbackTitle = document.getElementById('feedback-modal-title') as HTMLElement
  const feedbackSubtitle = document.getElementById('feedback-modal-subtitle') as HTMLElement
  const feedbackSentimentWrap = document.getElementById('feedback-sentiment-wrap') as HTMLElement
  const feedbackCategorySelect = document.getElementById('feedback-category') as HTMLSelectElement
  const feedbackReasoning = document.getElementById('feedback-reasoning') as HTMLTextAreaElement
  const feedbackGeneralize = document.getElementById('feedback-generalize') as HTMLInputElement
  const feedbackError = document.getElementById('feedback-error') as HTMLElement
  const feedbackSubmit = document.getElementById('feedback-submit') as HTMLButtonElement

  // When a feedback save is tied to a status transition, we store the pending
  // status here so the modal submit can run the status update after persisting
  // feedback. null means standalone (no status change after).
  let pendingStatusChange: string | null = null
  let pendingStatusButton: HTMLButtonElement | null = null

  function populateCategoryOptions(sentiment: 'positive' | 'negative') {
    const options = sentiment === 'positive' ? POSITIVE_CATEGORIES : NEGATIVE_CATEGORIES
    feedbackCategorySelect.innerHTML = '<option value="">Select a reason…</option>' +
      options.map(([key, label]) => `<option value="${key}">${label}</option>`).join('')
  }

  function openFeedbackModal(opts: {
    sentiment: 'positive' | 'negative' | null,  // null = standalone, let user pick
    statusTransition: string | null,            // null = no status change after
    statusButton: HTMLButtonElement | null,
    title: string,
    subtitle: string,
  }) {
    pendingStatusChange = opts.statusTransition
    pendingStatusButton = opts.statusButton
    feedbackTitle.textContent = opts.title
    feedbackSubtitle.textContent = opts.subtitle
    feedbackError.style.display = 'none'
    feedbackReasoning.value = ''
    feedbackGeneralize.checked = true
    feedbackSubmit.disabled = false
    feedbackSubmit.textContent = 'Save Feedback'

    if (opts.sentiment) {
      feedbackSentimentWrap.style.display = 'none'
      populateCategoryOptions(opts.sentiment)
    } else {
      feedbackSentimentWrap.style.display = 'block'
      const radios = feedbackSentimentWrap.querySelectorAll('input[name="feedback-sentiment"]') as NodeListOf<HTMLInputElement>
      radios.forEach(r => { r.checked = r.value === 'negative' })
      populateCategoryOptions('negative')
    }

    feedbackModal.style.display = 'flex'
  }

  function closeFeedbackModal() {
    feedbackModal.style.display = 'none'
    if (pendingStatusButton) {
      // User cancelled the status transition — restore the button.
      pendingStatusButton.disabled = false
      const s = pendingStatusButton.dataset.status || ''
      pendingStatusButton.textContent = s === 'no-bid' ? 'No-bid'
        : s === 'market-intel' ? 'Market Intel'
        : s.charAt(0).toUpperCase() + s.slice(1)
    }
    pendingStatusChange = null
    pendingStatusButton = null
  }

  document.getElementById('feedback-modal-close')?.addEventListener('click', closeFeedbackModal)
  document.getElementById('feedback-cancel')?.addEventListener('click', closeFeedbackModal)
  feedbackModal?.addEventListener('click', (e) => {
    if (e.target === feedbackModal) closeFeedbackModal()
  })

  // Sentiment toggle in standalone mode — repopulate categories.
  feedbackSentimentWrap?.querySelectorAll('input[name="feedback-sentiment"]').forEach(r => {
    r.addEventListener('change', (e) => {
      const val = (e.target as HTMLInputElement).value as 'positive' | 'negative'
      populateCategoryOptions(val)
    })
  })

  document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const leadId = feedbackModal.dataset.leadId
    const currentStatus = feedbackModal.dataset.currentStatus || ''
    const category = feedbackCategorySelect.value
    if (!category) {
      feedbackError.textContent = 'Please pick a reason.'
      feedbackError.style.display = 'block'
      return
    }

    // Determine sentiment: driven by status transition if present, else radio.
    let sentiment: 'positive' | 'negative'
    if (pendingStatusChange && POSITIVE_STATUSES.has(pendingStatusChange)) {
      sentiment = 'positive'
    } else if (pendingStatusChange && NEGATIVE_STATUSES.has(pendingStatusChange)) {
      sentiment = 'negative'
    } else {
      const checked = feedbackSentimentWrap.querySelector('input[name="feedback-sentiment"]:checked') as HTMLInputElement | null
      sentiment = (checked?.value === 'positive' ? 'positive' : 'negative')
    }

    feedbackError.style.display = 'none'
    feedbackSubmit.disabled = true
    feedbackSubmit.textContent = 'Saving...'

    try {
      // Step 1: save feedback.
      const fbRes = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          _addFeedback: {
            sentiment,
            category,
            reasoning: feedbackReasoning.value.trim() || null,
            generalize: feedbackGeneralize.checked,
            status_at_feedback: pendingStatusChange || currentStatus,
          }
        })
      })
      if (!fbRes.ok) {
        const data = await fbRes.json().catch(() => ({}))
        throw new Error(data.error || `Save failed (${fbRes.status})`)
      }

      // Step 2: if this was driven by a status transition, apply it now.
      if (pendingStatusChange) {
        const stRes = await fetch(`/api/leads/${leadId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: pendingStatusChange })
        })
        if (!stRes.ok) {
          const data = await stRes.json().catch(() => ({}))
          throw new Error(data.error || `Status update failed (${stRes.status})`)
        }
      }

      // Clear the button-restore handler before reload (status change succeeded).
      pendingStatusButton = null
      window.location.reload()
    } catch (err: any) {
      feedbackError.textContent = err?.message || 'Something went wrong.'
      feedbackError.style.display = 'block'
      feedbackSubmit.disabled = false
      feedbackSubmit.textContent = 'Save Feedback'
    }
  })

  // Standalone "+ Add Feedback" button.
  document.getElementById('standalone-feedback-btn')?.addEventListener('click', () => {
    openFeedbackModal({
      sentiment: null,
      statusTransition: null,
      statusButton: null,
      title: 'Add Feedback',
      subtitle: "Tell the agent what you think about this lead. Your reasoning trains Opus scoring for future leads.",
    })
  })

  // Status change buttons — intercept negative/positive transitions to require feedback.
  document.querySelectorAll('.status-change-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement
      const leadId = el.dataset.leadId
      const newStatus = el.dataset.status || ''

      if (NEGATIVE_STATUSES.has(newStatus) || POSITIVE_STATUSES.has(newStatus)) {
        const isPositive = POSITIVE_STATUSES.has(newStatus)
        el.disabled = true
        el.textContent = '...'
        openFeedbackModal({
          sentiment: isPositive ? 'positive' : 'negative',
          statusTransition: newStatus,
          statusButton: el,
          title: isPositive
            ? `Why pursuing this lead?`
            : `Why ${newStatus === 'no-bid' ? 'no-bidding' : newStatus + 'ing'} this lead?`,
          subtitle: isPositive
            ? "The agent learns what to chase next. Pick the primary driver — comments are optional but valuable."
            : "The agent learns what to filter out. Pick the primary reason — comments are optional but valuable.",
        })
        return
      }

      // Neutral transitions (new/tracking/market-intel): direct status change.
      el.textContent = '...'
      el.disabled = true
      try {
        const res = await fetch(`/api/leads/${leadId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        })
        if (res.ok) {
          window.location.reload()
        } else {
          const data = await res.json()
          alert('Error: ' + (data.error || 'Failed to update'))
          el.textContent = newStatus.charAt(0).toUpperCase() + newStatus.slice(1)
          el.disabled = false
        }
      } catch (err: any) {
        alert('Error: ' + (err?.message || err))
        el.textContent = newStatus.charAt(0).toUpperCase() + newStatus.slice(1)
        el.disabled = false
      }
    })
  })

  // Add note form
  document.getElementById('add-note-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const leadId = (document.getElementById('note-lead-id') as HTMLInputElement)?.value
    const noteInput = document.getElementById('note-text') as HTMLInputElement
    const text = noteInput?.value?.trim()
    if (!text) return

    const btn = (e.target as HTMLFormElement)?.querySelector('button') as HTMLButtonElement
    btn.textContent = '...'
    btn.disabled = true

    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _addNote: { author: 'Tom Keilty', text } })
      })
      if (res.ok) {
        window.location.reload()
      } else {
        alert('Failed to add note')
      }
    } catch (err: any) {
      alert('Error: ' + (err?.message || err))
    } finally {
      btn.textContent = 'Add'
      btn.disabled = false
    }
  })

  // Toggle contact form
  const contactForm = document.getElementById('add-contact-form') as HTMLFormElement
  document.getElementById('toggle-contact-form')?.addEventListener('click', () => {
    contactForm.style.display = contactForm.style.display === 'none' ? 'block' : 'none'
  })
  document.getElementById('cancel-contact')?.addEventListener('click', () => {
    contactForm.style.display = 'none'
    contactForm.reset()
  })

  // Save contact
  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const leadId = (document.getElementById('contact-lead-id') as HTMLInputElement)?.value
    const btn = document.getElementById('save-contact-btn') as HTMLButtonElement
    btn.textContent = 'Saving...'
    btn.disabled = true

    const contact = {
      lead_id: leadId,
      name: (document.getElementById('contact-name') as HTMLInputElement).value.trim(),
      role: (document.getElementById('contact-role') as HTMLSelectElement).value || null,
      company: (document.getElementById('contact-company') as HTMLInputElement).value.trim() || null,
      phone: (document.getElementById('contact-phone') as HTMLInputElement).value.trim() || null,
      email: (document.getElementById('contact-email') as HTMLInputElement).value.trim() || null,
      notes: (document.getElementById('contact-notes') as HTMLInputElement).value.trim() || null,
    }

    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _addContact: contact })
      })
      if (res.ok) {
        window.location.reload()
      } else {
        const data = await res.json()
        alert('Error: ' + (data.error || 'Failed to save contact'))
      }
    } catch (err: any) {
      alert('Error: ' + (err?.message || err))
    } finally {
      btn.textContent = 'Save Contact'
      btn.disabled = false
    }
  })

  // Toggle organization form
  const orgForm = document.getElementById('add-org-form') as HTMLFormElement
  document.getElementById('toggle-org-form')?.addEventListener('click', () => {
    if (!orgForm) return
    orgForm.style.display = orgForm.style.display === 'none' ? 'block' : 'none'
  })
  document.getElementById('cancel-org')?.addEventListener('click', () => {
    if (!orgForm) return
    orgForm.style.display = 'none'
    orgForm.reset()
  })

  // Save organization — stored as a lead_contacts row with entity_type='organization'.
  // Website goes into notes as "Website: <url> — <rest>" so it survives the
  // schema without needing a dedicated column.
  orgForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const leadId = (document.getElementById('org-lead-id') as HTMLInputElement)?.value
    const btn = document.getElementById('save-org-btn') as HTMLButtonElement
    btn.textContent = 'Saving...'
    btn.disabled = true

    const name = (document.getElementById('org-name') as HTMLInputElement).value.trim()
    const role = (document.getElementById('org-role') as HTMLSelectElement).value || null
    const website = (document.getElementById('org-website') as HTMLInputElement).value.trim()
    const phone = (document.getElementById('org-phone') as HTMLInputElement).value.trim() || null
    const notesText = (document.getElementById('org-notes') as HTMLInputElement).value.trim()
    const combinedNotes = website ? (notesText ? `Website: ${website} — ${notesText}` : `Website: ${website}`) : (notesText || null)

    const payload = {
      lead_id: leadId,
      name,
      role,
      company: name,
      phone,
      email: null,
      notes: combinedNotes,
      entity_type: 'organization',
    }

    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _addContact: payload })
      })
      if (res.ok) {
        window.location.reload()
      } else {
        const data = await res.json().catch(() => ({}))
        alert('Error: ' + (data.error || 'Failed to save organization'))
      }
    } catch (err: any) {
      alert('Error: ' + (err?.message || err))
    } finally {
      btn.textContent = 'Save Organization'
      btn.disabled = false
    }
  })

  // Edit contact / organization modal
  const editModal = document.getElementById('edit-entity-modal') as HTMLElement
  const editTitle = document.getElementById('edit-entity-title') as HTMLElement
  const editNameLabel = document.getElementById('edit-name-label') as HTMLElement
  const editRoleLabel = document.getElementById('edit-role-label') as HTMLElement
  const editCompanyRow = document.getElementById('edit-company-row') as HTMLElement
  const editWebsiteRow = document.getElementById('edit-website-row') as HTMLElement
  const editErr = document.getElementById('edit-entity-error') as HTMLElement

  function openEditModal(row: HTMLElement) {
    const entityType = row.dataset.entityType || 'person'
    const isOrg = entityType === 'organization'
    editTitle.textContent = isOrg ? 'Edit Organization' : 'Edit Contact'
    editNameLabel.textContent = isOrg ? 'Organization Name' : 'Name'
    editRoleLabel.textContent = isOrg ? 'Type' : 'Role'
    editCompanyRow.style.display = isOrg ? 'none' : 'block'
    editWebsiteRow.style.display = isOrg ? 'block' : 'none'

    ;(document.getElementById('edit-entity-id') as HTMLInputElement).value = row.dataset.contactId || ''
    ;(document.getElementById('edit-entity-type') as HTMLInputElement).value = entityType
    ;(document.getElementById('edit-entity-name') as HTMLInputElement).value = row.dataset.name || ''
    ;(document.getElementById('edit-entity-role') as HTMLSelectElement).value = row.dataset.role || ''
    ;(document.getElementById('edit-entity-company') as HTMLInputElement).value = row.dataset.company || ''
    ;(document.getElementById('edit-entity-phone') as HTMLInputElement).value = row.dataset.phone || ''
    ;(document.getElementById('edit-entity-email') as HTMLInputElement).value = row.dataset.email || ''

    if (isOrg) {
      ;(document.getElementById('edit-entity-website') as HTMLInputElement).value = row.dataset.website || ''
      ;(document.getElementById('edit-entity-notes') as HTMLInputElement).value = row.dataset.noteRest || ''
    } else {
      ;(document.getElementById('edit-entity-notes') as HTMLInputElement).value = row.dataset.notes || ''
    }

    editErr.style.display = 'none'
    editModal.style.display = 'flex'
  }

  function closeEditModal() {
    editModal.style.display = 'none'
  }

  document.querySelectorAll('.contact-row, .org-row').forEach(row => {
    row.addEventListener('click', (e) => {
      // Ignore clicks on anchor tags inside (tel:/mailto:/website)
      const target = e.target as HTMLElement
      if (target.closest('a')) return
      openEditModal(row as HTMLElement)
    })
  })

  document.getElementById('edit-entity-close')?.addEventListener('click', closeEditModal)
  document.getElementById('edit-entity-cancel')?.addEventListener('click', closeEditModal)
  editModal?.addEventListener('click', (e) => {
    if (e.target === editModal) closeEditModal()
  })

  document.getElementById('edit-entity-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const leadId = editModal.dataset.leadId
    const contactId = (document.getElementById('edit-entity-id') as HTMLInputElement).value
    const entityType = (document.getElementById('edit-entity-type') as HTMLInputElement).value
    const isOrg = entityType === 'organization'
    const saveBtn = document.getElementById('edit-entity-save') as HTMLButtonElement

    const name = (document.getElementById('edit-entity-name') as HTMLInputElement).value.trim()
    const role = (document.getElementById('edit-entity-role') as HTMLSelectElement).value || null
    const phone = (document.getElementById('edit-entity-phone') as HTMLInputElement).value.trim() || null
    const email = (document.getElementById('edit-entity-email') as HTMLInputElement).value.trim() || null
    const notesField = (document.getElementById('edit-entity-notes') as HTMLInputElement).value.trim()

    let company: string | null
    let combinedNotes: string | null
    if (isOrg) {
      const website = (document.getElementById('edit-entity-website') as HTMLInputElement).value.trim()
      company = name
      combinedNotes = website ? (notesField ? `Website: ${website} — ${notesField}` : `Website: ${website}`) : (notesField || null)
    } else {
      company = (document.getElementById('edit-entity-company') as HTMLInputElement).value.trim() || null
      combinedNotes = notesField || null
    }

    editErr.style.display = 'none'
    saveBtn.disabled = true
    saveBtn.textContent = 'Saving...'

    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          _updateContact: {
            id: contactId,
            name,
            role,
            company,
            phone,
            email,
            notes: combinedNotes,
            entity_type: entityType,
          }
        })
      })
      if (!res.ok) {
        const data = await res.json().catch(() => ({}))
        throw new Error(data.error || `Save failed (${res.status})`)
      }
      window.location.reload()
    } catch (err: any) {
      editErr.textContent = err?.message || 'Save failed'
      editErr.style.display = 'block'
      saveBtn.disabled = false
      saveBtn.textContent = 'Save'
    }
  })

  document.getElementById('edit-entity-delete')?.addEventListener('click', async () => {
    const contactId = (document.getElementById('edit-entity-id') as HTMLInputElement).value
    const entityType = (document.getElementById('edit-entity-type') as HTMLInputElement).value
    const leadId = editModal.dataset.leadId
    const label = entityType === 'organization' ? 'organization' : 'contact'
    if (!confirm(`Remove this ${label}? This cannot be undone.`)) return

    const delBtn = document.getElementById('edit-entity-delete') as HTMLButtonElement
    delBtn.disabled = true
    delBtn.textContent = 'Deleting...'

    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _deleteContact: { id: contactId } })
      })
      if (!res.ok) {
        const data = await res.json().catch(() => ({}))
        throw new Error(data.error || `Delete failed (${res.status})`)
      }
      window.location.reload()
    } catch (err: any) {
      editErr.textContent = err?.message || 'Delete failed'
      editErr.style.display = 'block'
      delBtn.disabled = false
      delBtn.textContent = 'Delete'
    }
  })

  // Outreach generator
  const outreachBtn = document.getElementById('generate-outreach-btn') as HTMLButtonElement
  outreachBtn?.addEventListener('click', async () => {
    const leadData = JSON.parse(outreachBtn.dataset.leadJson || '{}')
    const contactSelect = document.getElementById('outreach-contact-select') as HTMLSelectElement | null
    let contactName = null, contactRole = null, contactCompany = null

    if (contactSelect?.value) {
      const c = JSON.parse(contactSelect.value)
      contactName = c.name
      contactRole = c.role
      contactCompany = c.company
    }

    const loading = document.getElementById('outreach-loading')!
    const results = document.getElementById('outreach-results')!
    const errorEl = document.getElementById('outreach-error')!
    const empty = document.getElementById('outreach-empty')!

    outreachBtn.disabled = true
    outreachBtn.textContent = 'Generating...'
    loading.style.display = 'block'
    results.style.display = 'none'
    errorEl.style.display = 'none'
    empty.style.display = 'none'

    try {
      const res = await fetch('/api/outreach', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lead: leadData, contactName, contactRole, contactCompany })
      })

      if (!res.ok) {
        const data = await res.json().catch(() => ({}))
        throw new Error(data.error || `Request failed (${res.status})`)
      }

      const data = await res.json()

      document.getElementById('outreach-research')!.textContent = data.research || ''
      document.getElementById('outreach-email-subject')!.textContent = data.email?.subject || ''
      document.getElementById('outreach-email-body')!.textContent = data.email?.body || ''
      document.getElementById('outreach-linkedin')!.textContent = data.linkedin || ''

      loading.style.display = 'none'
      results.style.display = 'block'
    } catch (err: any) {
      loading.style.display = 'none'
      errorEl.textContent = err?.message || 'Failed to generate outreach'
      errorEl.style.display = 'block'
    } finally {
      outreachBtn.disabled = false
      outreachBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg> Draft Outreach'
    }
  })

  // Re-enrich: queue lead for next daily run by clearing enrichment_status
  document.getElementById('reenrich-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement
    const leadId = btn.dataset.leadId
    btn.disabled = true
    btn.textContent = 'Queuing...'
    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enrichment_status: null, enriched_at: null })
      })
      if (res.ok) {
        btn.textContent = '✓ Queued for next run'
        btn.style.color = '#065F46'
      } else {
        btn.textContent = 'Failed — try again'
        btn.disabled = false
      }
    } catch {
      btn.textContent = 'Failed — try again'
      btn.disabled = false
    }
  })

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLButtonElement
      const targetId = el.dataset.target || ''
      const text = document.getElementById(targetId)?.textContent || ''
      navigator.clipboard.writeText(text).then(() => {
        el.textContent = 'Copied!'
        setTimeout(() => { el.textContent = 'Copy' }, 2000)
      })
    })
  })
</script>
