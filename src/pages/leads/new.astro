---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Add Lead">
  <div class="mb-4">
    <a href="/leads" class="btn btn-ghost btn-sm">&larr; Back to Pipeline</a>
  </div>

  <h1 class="text-3xl font-bold mb-6">Add Lead Manually</h1>

  <form id="new-lead-form" class="card bg-base-200 max-w-2xl">
    <div class="card-body">
      <div class="form-control mb-4">
        <label class="label" for="project_name">
          <span class="label-text">Project Name *</span>
        </label>
        <input type="text" id="project_name" name="project_name" class="input input-bordered" required />
      </div>

      <div class="form-control mb-4">
        <label class="label" for="address">
          <span class="label-text">Address *</span>
        </label>
        <input type="text" id="address" name="address" class="input input-bordered" required />
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="form-control">
          <label class="label" for="project_type">
            <span class="label-text">Project Type</span>
          </label>
          <select id="project_type" name="project_type" class="select select-bordered">
            <option value="">Select...</option>
            <option value="multifamily">Multifamily</option>
            <option value="commercial">Commercial Office</option>
            <option value="mixed-use">Mixed-Use</option>
            <option value="hospitality">Hospitality</option>
            <option value="institutional">Institutional</option>
            <option value="industrial">Industrial</option>
            <option value="adaptive-reuse">Adaptive Reuse</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-control">
          <label class="label" for="estimated_value">
            <span class="label-text">Estimated Value</span>
          </label>
          <input type="text" id="estimated_value" name="estimated_value" class="input input-bordered" placeholder="$5M-10M" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="form-control">
          <label class="label" for="source_type">
            <span class="label-text">Source</span>
          </label>
          <select id="source_type" name="source_type" class="select select-bordered">
            <option value="manual">Manual Entry</option>
            <option value="referral">Referral</option>
          </select>
        </div>

        <div class="form-control">
          <label class="label" for="referral_from">
            <span class="label-text">Referral From</span>
          </label>
          <input type="text" id="referral_from" name="referral_from" class="input input-bordered" placeholder="Name (if referral)" />
        </div>
      </div>

      <div class="form-control mb-4">
        <label class="label" for="notes">
          <span class="label-text">Notes</span>
        </label>
        <textarea id="notes" name="notes" class="textarea textarea-bordered" rows="3" placeholder="What do you know about this project?"></textarea>
      </div>

      <div class="card-actions justify-end">
        <button type="submit" class="btn btn-primary">Add Lead</button>
      </div>
    </div>
  </form>
</Layout>
