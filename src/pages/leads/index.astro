---
import Layout from '../../layouts/Layout.astro'
import ScoreBadge from '../../components/ScoreBadge.astro'
import StatusBadge from '../../components/StatusBadge.astro'
import FitBadge from '../../components/FitBadge.astro'
import { supabase } from '../../lib/supabase.js'

const { data: leads } = await supabase
  .from('leads')
  .select('*')
  .order('actionability_score', { ascending: false })
  .limit(200)
---

<Layout title="Lead Pipeline">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
    <h1 class="text-primary-heading">Lead Pipeline</h1>
    <a href="/leads/new" class="btn-primary-custom">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
      Add Lead
    </a>
  </div>

  <!-- Filters -->
  <div style="display: flex; gap: 6px; margin-bottom: 20px; flex-wrap: wrap;" id="filter-bar">
    <button class="filter-btn active" data-filter="all">All ({leads?.length || 0})</button>
    <button class="filter-btn" data-filter="new">New</button>
    <button class="filter-btn" data-filter="tracking">Tracking</button>
    <button class="filter-btn" data-filter="pursuing">Pursuing</button>
    <button class="filter-btn" data-filter="won">Won</button>
    <button class="filter-btn" data-filter="lost">Lost</button>
  </div>

  {(leads && leads.length > 0) ? (
    <div style="display: flex; flex-direction: column; gap: 8px;" id="leads-list">
      {leads.map((lead: any) => (
        <a href={`/leads/${lead.id}`} class="lead-row" data-status={lead.status}>
          <ScoreBadge score={lead.actionability_score || 0} />
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 14px; font-weight: 600; color: #111827; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">{lead.project_name}</div>
            <div style="font-size: 13px; color: #9CA3AF; margin-top: 2px;">{lead.address || ''}</div>
          </div>
          <div style="display: flex; align-items: center; gap: 10px; flex-shrink: 0;">
            {lead.project_type && <span style="font-size: 12px; color: #6B7280; background: #F3F4F6; padding: 2px 8px; border-radius: 4px;">{lead.project_type}</span>}
            {lead.fit_type && <FitBadge fitType={lead.fit_type} />}
            <StatusBadge status={lead.status} />
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state card-surface">
      <p style="font-size: 15px; color: #6B7280;">No leads yet.</p>
      <p style="font-size: 13px; color: #9CA3AF; margin-top: 4px;">Add one manually or wait for the agent's first run.</p>
      <a href="/leads/new" class="btn-primary-custom" style="margin-top: 16px;">Add Your First Lead</a>
    </div>
  )}
</Layout>

<style>
  .filter-btn {
    padding: 5px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid #D1D5DB;
    background: white;
    cursor: pointer;
    color: #6B7280;
    transition: all 0.1s ease;
  }
  .filter-btn:hover { background: #F3F4F6; color: #111827; }
  .filter-btn.active { background: #1E2761; color: white; border-color: #1E2761; }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      document.querySelectorAll('.lead-row').forEach(row => {
        if (filter === 'all' || row.dataset.status === filter) {
          row.style.display = 'flex'
        } else {
          row.style.display = 'none'
        }
      })
    })
  })
</script>
