---
import Layout from '../layouts/Layout.astro'

const { slug } = Astro.params
---

<Layout title={`Briefing — ${slug}`}>
  <a href="/archive" class="btn-ghost-custom" style="margin-bottom: 16px;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    Back to Archive
  </a>

  <article class="card-surface" style="padding: 32px;">
    <h1 style="font-size: 22px; font-weight: 700; color: #111827; margin-bottom: 8px;">Briefing: {slug}</h1>
    <div class="empty-state" style="padding: 24px;">
      <p style="color: #9CA3AF;">This briefing hasn't been generated yet.</p>
    </div>
  </article>
</Layout>
