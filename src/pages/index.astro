---
import Layout from '../layouts/Layout.astro'
import LeadRow from '../components/LeadRow.astro'
import { supabase } from '../lib/supabase.js'

// Fetch live stats
const { count: activeCount } = await supabase
  .from('leads')
  .select('*', { count: 'exact', head: true })
  .in('status', ['new', 'tracking', 'pursuing'])

const monday = new Date()
monday.setDate(monday.getDate() - monday.getDay() + 1)
monday.setHours(0, 0, 0, 0)

const { count: hotCount } = await supabase
  .from('leads')
  .select('*', { count: 'exact', head: true })
  .gte('actionability_score', 8)
  .gte('created_at', monday.toISOString())

// Briefing = untriaged inbox. Once Tom moves a lead to tracking/pursuing it
// leaves the briefing and lives on the Leads page. New leads accumulate here
// across days so nothing gets missed if he doesn't log in daily.
const { data: openLeads } = await supabase
  .from('leads')
  .select('*')
  .eq('status', 'new')
  .order('actionability_score', { ascending: false })
  .limit(100)

const all = openLeads || []

// Hot: score >= 8 AND (GC open OR late stage) — pursue now
const hotLeads = all.filter((l: any) => {
  const s = (l.stage || '').toLowerCase()
  return (l.actionability_score || 0) >= 8 && (!l.gc_assigned || s.includes('bid') || s.includes('permit'))
}).slice(0, 8)

// Early Signals: score >= 6, planning/entitled — influence window
const hotIds = new Set(hotLeads.map((l: any) => l.id))
const earlyLeads = all.filter((l: any) => {
  if (hotIds.has(l.id)) return false
  const s = (l.stage || '').toLowerCase()
  return (l.actionability_score || 0) >= 6 && (s.includes('plan') || s.includes('entitle') || s.includes('design') || !s)
}).slice(0, 8)

// Watch: everything else with a score >= 5
const usedIds = new Set([...hotLeads, ...earlyLeads].map((l: any) => l.id))
const watchLeads = all.filter((l: any) => !usedIds.has(l.id) && (l.actionability_score || 0) >= 5).slice(0, 6)

const hasAny = hotLeads.length + earlyLeads.length + watchLeads.length > 0

// Fetch latest agent run
const { data: lastRun } = await supabase
  .from('agent_runs')
  .select('*')
  .order('run_date', { ascending: false })
  .limit(1)

const run = lastRun?.[0]
const sourcesActive = run?.sources_checked || 0
---

<Layout title="Today's Briefing">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
    <h1 class="text-primary-heading">Today's Briefing</h1>
    <a href="/leads/new" class="btn-primary-custom">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
      Add Lead
    </a>
  </div>

  <!-- Quick search -->
  <div style="margin-bottom: 24px;">
    <input type="text" id="dash-search" class="form-input" placeholder="Search leads..." style="max-width: 360px;" />
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px;">
    <div class="stat-card">
      <div class="stat-value" style="color: #111827;">{activeCount || 0}</div>
      <div class="stat-label">Active Leads</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: #DC2626;">{hotCount || 0}</div>
      <div class="stat-label">Hot This Week</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: #10B981;">{sourcesActive}</div>
      <div class="stat-label">Sources Checked</div>
    </div>
  </div>

  {hasAny ? (
    <div style="display: flex; flex-direction: column; gap: 28px;">
      {hotLeads.length > 0 && (
        <details class="bucket" data-bucket="hot" open>
          <summary>
            <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <h2 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Hot Leads</h2>
            <span style="font-size: 12px; color: #DC2626; font-weight: 600;">· pursue now</span>
            <span style="font-size: 12px; color: #9CA3AF;">({hotLeads.length})</span>
          </summary>
          <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
            {hotLeads.map((lead: any) => <LeadRow lead={lead} />)}
          </div>
        </details>
      )}

      {earlyLeads.length > 0 && (
        <details class="bucket" data-bucket="early" open>
          <summary>
            <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <h2 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Early Signals</h2>
            <span style="font-size: 12px; color: #B45309; font-weight: 600;">· influence window</span>
            <span style="font-size: 12px; color: #9CA3AF;">({earlyLeads.length})</span>
          </summary>
          <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
            {earlyLeads.map((lead: any) => <LeadRow lead={lead} />)}
          </div>
        </details>
      )}

      {watchLeads.length > 0 && (
        <details class="bucket" data-bucket="watch" open>
          <summary>
            <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <h2 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Watch List</h2>
            <span style="font-size: 12px; color: #6B7280; font-weight: 600;">· monitoring</span>
            <span style="font-size: 12px; color: #9CA3AF;">({watchLeads.length})</span>
          </summary>
          <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
            {watchLeads.map((lead: any) => <LeadRow lead={lead} />)}
          </div>
        </details>
      )}

      <div>
        <a href="/leads" class="btn-ghost-custom" style="font-size: 13px;">View all leads →</a>
      </div>
    </div>
  ) : (
    <div class="card-surface" style="padding: 24px;">
      <h2 style="font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 16px;">Inbox Zero</h2>
      <div class="empty-state">
        <p style="font-size: 15px; color: #6B7280;">No new leads to triage.</p>
        <p style="font-size: 13px; color: #9CA3AF; margin-top: 4px;">All surfaced leads have been moved to tracking, pursuing, or dismissed. Check the Leads page for active pipeline.</p>
      </div>
    </div>
  )}

  {run && (
    <div style="margin-top: 24px; padding: 16px 20px; background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 10px;">
      <div style="font-size: 13px; color: #9CA3AF;">
        Last agent run: {new Date(run.run_date).toLocaleString()} · {run.items_ingested} ingested · {run.items_evaluated} evaluated · {run.leads_created} new leads
      </div>
    </div>
  )}
</Layout>

<style>
  .bucket > summary {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .bucket > summary::-webkit-details-marker { display: none; }
  .bucket > summary .chev {
    color: #9CA3AF;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }
  .bucket[open] > summary .chev { transform: rotate(90deg); }
</style>

<script>
  const dashSearch = document.getElementById('dash-search')
  dashSearch?.addEventListener('input', () => {
    const q = (dashSearch as HTMLInputElement).value.toLowerCase().trim()
    document.querySelectorAll('.lead-row').forEach(row => {
      const el = row as HTMLElement
      if (!q || (el.dataset.search || '').includes(q)) {
        el.style.display = 'flex'
      } else {
        el.style.display = 'none'
      }
    })
  })

  document.querySelectorAll<HTMLDetailsElement>('.bucket').forEach(d => {
    const key = `bucket:${d.dataset.bucket}`
    const stored = localStorage.getItem(key)
    if (stored === 'closed') d.open = false
    d.addEventListener('toggle', () => {
      localStorage.setItem(key, d.open ? 'open' : 'closed')
    })
  })
</script>
