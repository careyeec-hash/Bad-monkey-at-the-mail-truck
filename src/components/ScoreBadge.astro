---
interface Props {
  score: number
}

const { score } = Astro.props

const badgeClass = score >= 9
  ? 'badge-error'
  : score >= 7
    ? 'badge-warning'
    : score >= 5
      ? 'badge-info'
      : 'badge-neutral'
---

<span class:list={['badge', 'badge-lg', 'font-bold', badgeClass]}>
  {score}/10
</span>
