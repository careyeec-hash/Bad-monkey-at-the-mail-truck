---
interface Props {
  fitType: string
}

const { fitType } = Astro.props

const cls: Record<string, string> = {
  'gc-scope': 'fit-gc',
  'concrete-scope': 'fit-concrete',
  'both': 'fit-both',
}

const labels: Record<string, string> = {
  'gc-scope': 'GC Scope',
  'concrete-scope': 'Concrete',
  'both': 'GC + Concrete',
}
---

<span class:list={['fit-pill', cls[fitType] || 'fit-gc']}>
  {labels[fitType] || fitType}
</span>
