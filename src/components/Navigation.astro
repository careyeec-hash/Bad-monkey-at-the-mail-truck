---
const currentPath = Astro.url.pathname
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/'
  return currentPath.startsWith(path)
}
---

<!-- Desktop Sidebar -->
<nav class="sidebar">
  <div class="sidebar-logo" style="display: flex; align-items: center; gap: 10px;">
    <img src="/bad-monkey-favicon.svg" alt="" width="28" height="28" style="border-radius: 6px;" />
    Bad Monkey
  </div>

  <div class="sidebar-nav">
    <a href="/" class:list={["sidebar-link", { active: isActive('/') && !isActive('/archive') && !isActive('/leads') }]}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
      Briefings
    </a>
    <a href="/leads" class:list={["sidebar-link", { active: isActive('/leads') && !isActive('/leads/new') }]}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Leads
    </a>
    <a href="/crm" class:list={["sidebar-link", { active: isActive('/crm') }]}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="4" x2="9" y2="20"/></svg>
      CRM
    </a>
    <a href="/archive" class:list={["sidebar-link", { active: isActive('/archive') }]}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2"/><path d="M21 12V10a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
      Archive
    </a>

    <div style="flex: 1;"></div>

    <a href="/leads/new" class="sidebar-link" style="margin-top: auto; color: rgba(255,255,255,0.9);">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
      Add Lead
    </a>
  </div>

  <div style="padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 12px; color: rgba(255,255,255,0.4);">
    Bristlecone Construction
  </div>
</nav>

<!-- Mobile Bottom Bar -->
<div class="mobile-bar">
  <a href="/" class:list={[{ active: isActive('/') && !isActive('/archive') && !isActive('/leads') }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
    Briefings
  </a>
  <a href="/leads" class:list={[{ active: isActive('/leads') && !isActive('/leads/new') }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Leads
  </a>
  <a href="/crm" class:list={[{ active: isActive('/crm') }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="4" x2="9" y2="20"/></svg>
    CRM
  </a>
  <a href="/archive" class:list={[{ active: isActive('/archive') }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2"/><path d="M21 12V10a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
    Archive
  </a>
  <a href="/leads/new" class:list={[{ active: currentPath === '/leads/new' }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
    Add
  </a>
</div>
