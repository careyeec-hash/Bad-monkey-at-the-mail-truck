---
interface Props {
  date: string
  hotLeads: number
  watchList: number
  totalItems: number
  slug: string
}

const { date, hotLeads, watchList, totalItems, slug } = Astro.props
---

<a href={`/${slug}`} class="card-surface" style="display: block; padding: 20px; text-decoration: none; color: inherit; transition: box-shadow 0.15s ease;">
  <div style="display: flex; align-items: center; justify-content: space-between;">
    <div>
      <div style="font-size: 15px; font-weight: 600; color: #111827;">{date}</div>
      <div style="font-size: 13px; color: #9CA3AF; margin-top: 2px;">{totalItems} items evaluated</div>
    </div>
    <div style="display: flex; gap: 16px; text-align: center;">
      {hotLeads > 0 && (
        <div>
          <div style="font-size: 20px; font-weight: 700; color: #DC2626;">{hotLeads}</div>
          <div style="font-size: 11px; color: #9CA3AF;">Hot</div>
        </div>
      )}
      <div>
        <div style="font-size: 20px; font-weight: 700; color: #D97706;">{watchList}</div>
        <div style="font-size: 11px; color: #9CA3AF;">Watch</div>
      </div>
    </div>
  </div>
</a>
