---
import ScoreBadge from './ScoreBadge.astro'
import StatusBadge from './StatusBadge.astro'
import FitBadge from './FitBadge.astro'
import SectorBadge from './SectorBadge.astro'

interface Props {
  lead: any
}

const { lead } = Astro.props

let sourceHost = ''
try { if (lead.source_url) sourceHost = new URL(lead.source_url).hostname.replace(/^www\./, '') } catch {}

const stage = lead.stage && String(lead.stage).trim()
const gcLabel = lead.gc_assigned
  ? (lead.gc_name ? `GC: ${lead.gc_name}` : 'GC: assigned')
  : 'GC: open'
const gcOpen = !lead.gc_assigned
const why = lead.why_it_matters && String(lead.why_it_matters).trim()
const score = lead.actionability_score || 0
const sector = (lead.project_type || '').toLowerCase().trim()

// Primary contact for the CRM list column — first person-type row (or
// anything, if entity_type isn't populated on existing data).
const contacts = Array.isArray(lead.lead_contacts) ? lead.lead_contacts : []
const people = contacts.filter((c: any) => !c.entity_type || c.entity_type === 'person')
const primaryContact = people[0] || contacts[0] || null
const contactLabel = primaryContact
  ? [primaryContact.name, primaryContact.role].filter(Boolean).join(' · ')
  : null
const extraContactCount = Math.max(0, contacts.length - 1)

const searchText = [lead.project_name, lead.address, lead.source_name, lead.gc_name, lead.project_type, ...contacts.map((c: any) => c.name)].filter(Boolean).join(' ').toLowerCase()

// Source date — prefer briefing_date, fall back to created_at
const sourceDate = lead.briefing_date || lead.created_at
const sourceDateLabel = sourceDate ? new Date(sourceDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null

// Sort keys: prefer first_seen_at (when agent discovered it), fall back to created_at
const sortDate = lead.first_seen_at || lead.created_at || lead.briefing_date || ''
const sortName = (lead.project_name || '').toLowerCase()
---

<a href={`/leads/${lead.id}`} class="lead-row" data-status={lead.status} data-score={score} data-sector={sector} data-search={searchText} data-date={sortDate} data-name={sortName}>
  <ScoreBadge score={score} />

  <div style="flex: 1; min-width: 0;">
    <div style="font-size: 14px; font-weight: 600; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
      {lead.project_name}
    </div>
    <div style="font-size: 12px; color: #6B7280; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
      {lead.address || lead.source_name || '—'}
    </div>
    <div style="font-size: 12px; color: #4B5563; margin-top: 4px; display: flex; flex-wrap: wrap; gap: 6px 10px; align-items: center;">
      <span style={`color: ${stage ? '#111827' : '#9CA3AF'};`}>
        {stage || 'stage: —'}
      </span>
      <span style="color: #D1D5DB;">·</span>
      <span style={`color: ${gcOpen ? '#B45309' : '#374151'}; font-weight: ${gcOpen ? 600 : 400};`}>
        {gcLabel}
      </span>
      <span style="color: #D1D5DB;">·</span>
      <span style={`color: ${contactLabel ? '#111827' : '#9CA3AF'};`}>
        {contactLabel ? (
          <>
            👤 {contactLabel}
            {extraContactCount > 0 && <span style="color: #9CA3AF; font-weight: 400;"> +{extraContactCount}</span>}
          </>
        ) : 'contact: —'}
      </span>
      {sourceDateLabel && (
        <>
          <span style="color: #D1D5DB;">·</span>
          <span style="color: #9CA3AF;">{sourceDateLabel}</span>
        </>
      )}
    </div>
    {why && (
      <div style="font-size: 12px; color: #6B7280; margin-top: 4px; font-style: italic; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
        {why}
      </div>
    )}
  </div>

  <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
    {lead.project_type && <SectorBadge sector={lead.project_type} />}
    {lead.source_url ? (
      <button
        type="button"
        onclick={`event.preventDefault(); event.stopPropagation(); window.open('${lead.source_url}', '_blank', 'noopener');`}
        style="font-size: 11px; color: #4A6FA5; background: #EEF2FF; border: 1px solid #C7D2FE; padding: 2px 8px; border-radius: 999px; cursor: pointer; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
        title={lead.source_url}
      >↗ {sourceHost || 'source'}</button>
    ) : (
      <button
        type="button"
        onclick={`event.preventDefault(); event.stopPropagation(); window.open('https://www.google.com/search?q=' + encodeURIComponent('${lead.project_name.replace(/'/g, "\\'")} Arizona construction'), '_blank', 'noopener');`}
        style="font-size: 11px; color: #9CA3AF; background: #F3F4F6; border: 1px solid #E5E7EB; padding: 2px 8px; border-radius: 999px; cursor: pointer;"
        title="Search for this project"
      >🔍 search</button>
    )}
    {lead.fit_type && <FitBadge fitType={lead.fit_type} />}
    <StatusBadge status={lead.status} />
  </div>
</a>
