---
import ScoreBadge from './ScoreBadge.astro'
import StatusBadge from './StatusBadge.astro'
import FitBadge from './FitBadge.astro'

interface Props {
  id: string
  projectName: string
  address: string
  score: number
  status: string
  fitType: string
  projectType: string
  actionItem: string
}

const { id, projectName, address, score, status, fitType, projectType, actionItem } = Astro.props
---

<a href={`/leads/${id}`} class="lead-row">
  <ScoreBadge score={score} />
  <div style="flex: 1; min-width: 0;">
    <div style="font-size: 15px; font-weight: 600; color: #111827;">{projectName}</div>
    <div style="font-size: 13px; color: #9CA3AF; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{address}</div>
  </div>
  <div style="display: flex; align-items: center; gap: 12px; flex-shrink: 0;">
    {projectType && <span style="font-size: 12px; color: #6B7280; background: #F3F4F6; padding: 2px 8px; border-radius: 4px;">{projectType}</span>}
    {fitType && <FitBadge fitType={fitType} />}
    <StatusBadge status={status} />
  </div>
</a>
