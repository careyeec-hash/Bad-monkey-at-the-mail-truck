---
import ScoreBadge from './ScoreBadge.astro'
import StatusBadge from './StatusBadge.astro'
import FitBadge from './FitBadge.astro'

interface Props {
  id: string
  projectName: string
  address: string
  score: number
  status: string
  fitType: string
  projectType: string
  actionItem: string
}

const { id, projectName, address, score, status, fitType, projectType, actionItem } = Astro.props
---

<tr class="hover">
  <td><ScoreBadge score={score} /></td>
  <td>
    <a href={`/leads/${id}`} class="link link-primary font-semibold">{projectName}</a>
    <div class="text-sm text-base-content/60">{address}</div>
  </td>
  <td><span class="badge badge-outline">{projectType}</span></td>
  <td><FitBadge fitType={fitType} /></td>
  <td><StatusBadge status={status} /></td>
  <td class="text-sm max-w-xs truncate">{actionItem}</td>
</tr>
